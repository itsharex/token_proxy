  "devDependencies": {
    "@inlang/paraglide-js": "^2.7.2",
    "@tauri-apps/cli": "^2",
    "@tanstack/router-cli": "^1.114.3",
    "@tanstack/router-plugin": "^1.114.3",
    "@types/node": "^25.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.0.4"
  }
}
